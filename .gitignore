# This .gitignore file is configured for Unity 6 and Firebase projects.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[尝]logs/
/[MemoryCaptures]/

# Asset meta files for folders that are ignored
/[Ll]ibrary.meta
/[Tt]emp.meta
/[Oo]bj.meta
/[Bb]uild.meta
/[Bb]uilds.meta
/[尝]logs.meta

# Autogenerated VS/MonoDevelop Project Files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.tlog

# Unity 3D Generated File Types
*.ko
*.meta.bin
*.meta.bin.meta

# OS Generated Files
.DS_Store
Thumbs.db

# Firebase Local Configs (Exclude private keys/secrets if any)
.firebaserc
firebase-debug.log
firestore-debug.log
ui-debug.log

# Exclude potential local credentials
google-services.json
google-services-desktop.json
